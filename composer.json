{
    "name": "aimeos/pagible-themes-bold",
    "description": "Pagible CMS - Bold theme with brutalist design, heavyweight typography, and high-contrast layouts",
    "keywords": ["laravel", "cms", "theme", "bold", "brutalist"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-theme": "*@dev"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\BoldServiceProvider"
            ]
        }
    }
}
